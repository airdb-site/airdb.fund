---
import ProductLayout from "../../layouts/ProductLayout.astro";

const CONCERNS = [
  {
    id: "funding",
    q: "关于钱从哪里来的问题",
    ask: "「你们的资金来源是什么？会不会拿别人的钱办自己的事？」",
    answer:
      "现阶段资金全部来自自有基金，不接受外部捐赠、不对外募集。每一笔基金注入都会与支出一样逐笔列入公开账目。",
    promise: "正式运作后，自有基金注入将附凭证编号公示，与支出同一标准。",
  },
  {
    id: "no-donation",
    q: "关于为什么不接受捐赠的问题",
    ask: "「做公益为什么不募捐？是不是没有募捐资格？」",
    answer:
      "是的，我们目前没有公开募捐资格，也不打算在流程跑通之前开放捐赠。发展路线的阶段一就是用自有资金把项目做实：先自证账目和流程经得起看，再谈请别人出钱。",
    promise: "如果未来开放捐赠，会先完成相应登记与制度建设，并提前在信息公开页说明；转账如何记录、如何查询的规则会在开放前公布，而不是之后补。",
  },
  // 2026-07-14 发起人确认按"尚未登记"表述发布。
  // 完成法人登记后需改写本条：写明登记机关与统一社会信用代码，并挂证书原件。
  {
    id: "identity",
    q: "关于法律身份的问题",
    ask: "「你们是正式登记的基金会吗？『基金会』三个字有没有名不副实？」",
    answer:
      "我们目前处于筹备阶段，由 airdb 团队发起、以自有基金运作，尚未完成基金会法人登记。在完成登记之前，「airdb 基金会」是一个公益实践的名字，不是法律主体的名字——这一点我们不回避。",
    promise: "登记进展会在本页更新；完成登记后，证书原件将挂在网站上可供下载。",
  },
  {
    id: "supervision",
    q: "关于怎么监督我们的问题",
    ask: "「你们说欢迎监督，具体怎么监督？」",
    answer:
      "四个入口：逐笔账目在公开账目页；每个项目的立项与进展在项目档案页；我们的自查在监督简报页按期发布；我们向谁看齐、按什么标准检验自己在对标与标准页。",
    promise: "对账目或执行的疑问，写信给 info@airdb.com，共性问题在信息公开页公开回应。",
  },
  {
    id: "privacy",
    q: "关于受助人隐私的问题",
    ask: "「账目公开会不会把受助学生、寻亲家庭也暴露了？」",
    answer:
      "不会。公开以不伤害受助人为前提：账目公开的是金额与用途，受助人以匿名编号出现；寻亲个案细节永不公开。具体边界写在风险与应对页的「披露边界」一节。",
    promise: "涉及未成年人的任何公开内容，遵循匿名化处理并需监护人同意。",
  },
  {
    id: "failure",
    q: "关于做砸了怎么办的问题",
    ask: "「项目失败、钱花错了，你们会承认吗？」",
    answer:
      "会。披露制度里专门有「问题披露」条款：执行偏差、预算超支、判断失误，同样公开说明原因与改进措施；年度总结固定包含「没做成什么」。",
    promise: "重大问题参照本页格式逐条说明：发生了什么、损失多少、谁负责、怎么补救、制度怎么改。",
  },
];
---

<ProductLayout
  title="公众关切 — airdb 基金会"
  description="airdb 基金会公众关切：钱从哪来、为什么不募捐、法律身份、怎么监督——这些问题现在就答，不等被问。"
  path="/concerns/"
>
  <div class="shell page-hero">
    <p class="notice">这些问题现在就答 · 不等被问 · 有新的共性问题会补充进来</p>
    <h1>公众关切</h1>
    <p class="lede">
      公益机构最常被问倒的问题，我们试着在被问之前先答。每条都是同一个格式：
      把质疑原样写出来、正面回答、给出可检验的承诺。如果你觉得哪条答得避重就轻，
      写信给 <a href="mailto:info@airdb.com">info@airdb.com</a>。
    </p>
    <nav class="toc" aria-label="本页目录">
      {CONCERNS.map((c) => (
        <a href={`#${c.id}`}>{c.q.replace("关于", "").replace("的问题", "")}</a>
      ))}
    </nav>
  </div>

  <div class="shell doc-body">
    {CONCERNS.map((c, i) => (
      <section class="doc-section" id={c.id}>
        <h2><span class="sec-no">{String(i + 1).padStart(2, "0")} · 关切</span>{c.q}</h2>
        <p><em>{c.ask}</em></p>
        <p>{c.answer}</p>
        <p><strong>我们的承诺：</strong>{c.promise}</p>
      </section>
    ))}
  </div>
</ProductLayout>

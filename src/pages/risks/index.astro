---
import ProductLayout from "../../layouts/ProductLayout.astro";

const GENERAL_RISKS = [
  {
    risk: "资金管理失当",
    detail: "自有基金规模有限，一笔失误占比就不小；也不排除内部人员挪用、串谋的可能。",
    mitigation: "账目逐笔公开、支出附凭证编号；大额支出事前公开说明用途；出现损失时披露金额与原因，不论多难看。",
  },
  {
    risk: "执行能力不足",
    detail: "筹备期以志愿协作为主，人手与专业性不稳定，项目可能延期、走样甚至中途停摆。",
    mitigation: "项目从小规模起步，立项书写明评估方式；执行偏差在季度进展中如实披露；停摆的项目公开说明原因与善后。",
  },
  {
    risk: "判断失误",
    detail: "资助对象选错、优先级排错、把钱花在了不该花的地方——善意不保证正确。",
    mitigation: "立项书公开决策依据，欢迎事前挑战；年度总结固定包含「没做成什么、明年怎么改」。",
  },
];

const PROGRAM_RISKS = [
  {
    prog: "人道主义救援",
    risk: "物资时效与最后一公里：灾害信息混乱时，物资可能送错、送迟或被截留。",
    mitigation: "优先与在地成熟组织协作而非自建渠道；物资去向附交接凭证。",
  },
  {
    prog: "寻亲回家",
    risk: "隐私风险最高的方向：寻亲信息涉及未成年人与家庭创伤，扩散不当会造成二次伤害；线索真实性也难以核验。",
    mitigation: "只与「宝贝回家」等有既定核验流程的平台协作，不自行发布个案信息；个案细节永不公开（见下方披露边界）。",
  },
  {
    prog: "教育支持",
    risk: "受助学生被标签化、隐私被暴露；资助如果中断，伤害大于不开始。",
    mitigation: "受助人信息匿名化；每笔资助承诺覆盖完整周期（学期/学年）后才立项。",
  },
  {
    prog: "开源科技",
    risk: "资助的项目烂尾、维护者拿钱后消失，或资助变成了变相的关系输送。",
    mitigation: "资助规则与评审标准公开（规划中，将借鉴 Apache 成熟度模型）；受助项目定期公开进展报告，烂尾如实记录。",
  },
];
---

<ProductLayout
  title="风险与应对 — airdb 基金会"
  description="airdb 基金会公开自己的风险清单：可能出什么问题、如何缓解、出问题时披露什么。预先写下，出事时以此为准。"
  path="/risks/"
>
  <div class="shell page-hero">
    <p class="notice">筹备阶段预先写下 · 出问题时以此为准，不另立新规</p>
    <h1>风险与应对</h1>
    <p class="lede">
      做事就会出错。与其出事后临时解释，不如现在就写清楚：可能出什么问题、
      我们怎么防、真出了问题会披露什么。这一页是我们对自己的预先约束。
    </p>
    <nav class="toc" aria-label="本页目录">
      <a href="#general">通用风险</a>
      <a href="#programs">分方向风险</a>
      <a href="#boundary">披露边界</a>
      <a href="#promise">出事时的承诺</a>
    </nav>
  </div>

  <div class="shell doc-body">
    <section class="doc-section" id="general">
      <h2><span class="sec-no">01 · 通用</span>通用风险</h2>
      <div class="table-scroll">
        <table class="doc-table">
          <thead>
            <tr><th scope="col">风险</th><th scope="col">具体是什么</th><th scope="col">我们的应对</th></tr>
          </thead>
          <tbody>
            {GENERAL_RISKS.map((r) => (
              <tr><td>{r.risk}</td><td>{r.detail}</td><td>{r.mitigation}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="doc-section" id="programs">
      <h2><span class="sec-no">02 · 分方向</span>分方向风险</h2>
      <p>四个项目方向的风险并不相同，寻亲方向的隐私风险尤其高：</p>
      <div class="table-scroll">
        <table class="doc-table">
          <thead>
            <tr><th scope="col">方向</th><th scope="col">主要风险</th><th scope="col">我们的应对</th></tr>
          </thead>
          <tbody>
            {PROGRAM_RISKS.map((r) => (
              <tr><td>{r.prog}</td><td>{r.risk}</td><td>{r.mitigation}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="doc-section" id="boundary">
      <h2><span class="sec-no">03 · 边界</span>披露边界：什么会公开，什么不会</h2>
      <p><strong>会公开：</strong>执行偏差、预算超支、项目停摆、资金损失（含金额与原因）、判断失误及改进措施。这些写进了<a href="/transparency/#policy">披露制度</a>的「问题披露」条款。</p>
      <p><strong>不会公开：</strong>能够识别到个人的受助者信息、寻亲个案的细节、未成年人及其家庭的可追溯信息。</p>
      <p><strong>为什么：</strong>公开以不伤害受助人为前提。当「让公众看到」与「保护当事人」冲突时，我们选后者，并在披露中说明"此处因隐私原因略去"，而不是假装无事发生。</p>
    </section>

    <section class="doc-section" id="promise">
      <h2><span class="sec-no">04 · 承诺</span>出事时的承诺</h2>
      <p>
        如果本页列出的风险成真，或出现了没预见到的问题：我们会在确认事实后主动披露，
        参照<a href="/concerns/">公众关切</a>页的格式逐条说明——发生了什么、损失多少、
        谁负责、怎么补救、制度怎么改。你也可以随时写信给
        <a href="mailto:info@airdb.com">info@airdb.com</a> 提出你看到的风险，
        共性问题我们会补充进本页。
      </p>
    </section>
  </div>
</ProductLayout>
